{
  "buildCommand": "cd apps/web && bun run build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "bun install",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- ':(top)apps/web' ':(top)packages/types' ':(top)vercel.json'",
  "crons": [
    { "path": "/api/cron/purge-accounts", "schedule": "0 3 * * *" }
  ]
}
