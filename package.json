{
  "name": "health-agent",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "dev:local": "bun run --cwd apps/web dev:local",
    "build": "bun run --cwd apps/web build",
    "start": "bun run --cwd apps/web start",
    "db:migrate": "bun run --cwd apps/web db:migrate",
    "db:generate": "bun run --cwd apps/web db:generate",
    "seed:staff": "bun run --cwd apps/web seed:staff",
    "migrate:encrypt-pii": "bun run --cwd apps/web migrate:encrypt-pii",
    "type-check": "bun run --cwd apps/web type-check",
    "lint": "bun run --cwd apps/web lint",
    "lint:fix": "bun run --cwd apps/web lint:fix"
  }
}
