{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": { "simulator": false },
      "android": { "buildType": "apk" }
    },
    "production": {
      "channel": "production",
      "ios": { "distribution": "store" },
      "android": { "buildType": "app-bundle" }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascApiKeyPath": "./secrets/AuthKey.p8",
        "ascApiKeyId": "$APP_STORE_CONNECT_API_KEY_ID",
        "ascApiIssuerId": "$APP_STORE_CONNECT_ISSUER_ID"
      }
    }
  },
  "update": {
    "channel": "production"
  }
}
