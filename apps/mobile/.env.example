# Mobile build + release pipeline secrets.
# Copy to apps/mobile/.env and fill in real values for local use.
# In CI, inject via the platform's secret store.

# --- App Store Connect (TestFlight + EAS submit) ---
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
# Contents of AuthKey_XXXXXXXXXX.p8 (raw string, not a filepath)
APP_STORE_CONNECT_API_KEY=

# --- Android release signing (referenced by android/gradle.properties) ---
ANDROID_KEYSTORE_PATH=./android/health-agent.keystore
ANDROID_KEYSTORE_ALIAS=health-agent
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_PASSWORD=

# --- Google Sign-In (expo-auth-session) ---
# OAuth client IDs from Google Cloud Console, created against bundle/package
# com.zabaca.veladon. The iOS client ID is already provisioned in secrets.yaml
# (EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID); the Android one still needs creating.
# Bundled into the app at build time (EXPO_PUBLIC_ prefix = client-visible).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Backend the mobile app talks to. iOS sim: http://localhost:3000.
# Android emulator: http://10.0.2.2:3000. Physical device: a tunnel URL.
EXPO_PUBLIC_API_URL=
