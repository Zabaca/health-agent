# Maestro E2E test credentials. Copy to .maestro/.env and fill in.
# The e2e script (scripts/e2e.sh) loads this file and passes each var to
# Maestro via -e. NEVER commit .maestro/.env (it's gitignored).

# A seeded test account on the backend the app build points at
# (EXPO_PUBLIC_API_URL). Used by flows/login.yaml.
MAESTRO_EMAIL=
MAESTRO_PASSWORD=
