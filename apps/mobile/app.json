{
  "expo": {
    "name": "Veladon",
    "slug": "veladon",
    "scheme": "zabaca",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "platforms": [
      "ios",
      "android"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F4F1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zabaca.veladon",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSHealthShareUsageDescription": "Veladon reads your health data to display vitals, activity, sleep, and lab results on your dashboard.",
        "NSHealthUpdateUsageDescription": "Veladon writes health data to keep your records in sync."
      }
    },
    "android": {
      "package": "com.zabaca.veladon",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3D8A5A"
      },
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ]
    },
    "plugins": [
      "expo-updates",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Veladon uses the camera to capture photos of your health documents for upload."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Veladon accesses your photo library so you can upload existing photos of health documents."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "updates": {
      "url": "https://u.expo.dev/FILL_IN_PROJECT_ID"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
