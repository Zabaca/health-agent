*_backup.pen

# Expo / React Native (apps/mobile)
apps/mobile/.expo/
apps/mobile/build/
apps/mobile/node_modules/
apps/mobile/ios/build/
apps/mobile/ios/Pods/
apps/mobile/ios/DerivedData/
apps/mobile/ios/*.xcworkspace/xcuserdata/
apps/mobile/ios/*.xcodeproj/xcuserdata/
apps/mobile/android/.gradle/
apps/mobile/android/build/
apps/mobile/android/app/build/
apps/mobile/android/.idea/
apps/mobile/android/local.properties

# Mobile signing / secrets
*.jks
*.p8
*.p12
*.mobileprovision
apps/mobile/secrets/

# SOPS decrypted
.decrypted~*
# App Store metadata holds reviewer demo credentials — commit only the sops-encrypted
# store.config.enc.json; the decrypted plaintext is generated at push time.
apps/mobile/store.config.json
# EAS Update code-signing private key — commit only the sops-encrypted .enc;
# decrypted plaintext is generated at publish time.
apps/mobile/keys/private-key.pem
# ...but the certificate + public key are NOT secret (cert is public; public key
# is contained in it) and `eas update` reads the cert path from app.json — keep
# them tracked despite the global *.pem ignore above.
!apps/mobile/certs/certificate.pem
!apps/mobile/keys/public-key.pem

# graphify knowledge graph (locally rebuilt by the post-commit hook)
graphify-out/