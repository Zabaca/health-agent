.env.staging
.env.production
.env.production.local

# Maestro E2E
# .maestro/.env is covered by the .env rule above; this documents intent and
# catches any local report output. Flows + .env.example stay committed.
apps/mobile/.maestro/.env
apps/mobile/.maestro/**/report.*

# Private keys / certificates
*.pem
*.key
*.cert
*.crt

# Database
prisma/dev.db
prisma/dev.db-journal
*.db
*.db-journal
*.db-wal
*.db-shm
*.db.bak*

# Uploads
public/uploads/*
!public/uploads/.gitkeep
apps/web/public/uploads/*
!apps/web/public/uploads/.gitkeep

