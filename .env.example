# ── Database ──────────────────────────────────────────────────────────────────
# libsql connection URL (e.g. file:local.db for local dev, or a Turso remote URL)
DATABASE_URL=""
# Auth token required for remote Turso connections; leave blank for local file DBs
DATABASE_AUTH_TOKEN=""

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret used to sign NextAuth JWTs — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Use the same Client ID for the web "Authorized JavaScript origins" callback
# AND for the mobile Google sign-in SDK (mobile sends the resulting ID token to
# /api/auth/google/mobile, which verifies it server-side).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Native-mobile Google client IDs. The mobile google/mobile route verifies the
# ID token's audience against AUTH_GOOGLE_ID (web) OR these, so the native flow
# (whose token aud is the iOS/Android client) is accepted server-side.
GOOGLE_IOS_CLIENT_ID=""
GOOGLE_ANDROID_CLIENT_ID=""

# Apple Sign in with Apple. The web client secret JWT is computed lazily at
# runtime from the raw key material (see lib/apple-secret.ts) — no pre-generated
# AUTH_APPLE_SECRET to rotate every 6 months.
#   AUTH_APPLE_ID            — Services ID (web flow, e.g. com.zabaca.veladon.web)
#   AUTH_APPLE_BUNDLE_ID     — app bundle ID (native mobile flow, com.zabaca.veladon)
#   AUTH_APPLE_SIGNIN_KEY    — contents of the Sign in with Apple .p8 (PEM; newlines as \n)
#   AUTH_APPLE_TEAM_ID       — Apple Team ID (10 chars; shared team-wide)
#   AUTH_APPLE_SIGNIN_KEY_ID — Key ID of the sign-in .p8 (10 chars)
# (A future APNs push .p8 would use its own vars, e.g. APPLE_APNS_KEY / APPLE_APNS_KEY_ID.)
# The mobile apple/mobile route accepts a token whose aud is either AUTH_APPLE_ID
# (Services ID, web) or AUTH_APPLE_BUNDLE_ID (bundle ID, mobile).
AUTH_APPLE_ID=""
AUTH_APPLE_BUNDLE_ID=""
AUTH_APPLE_SIGNIN_KEY=""
AUTH_APPLE_TEAM_ID=""
AUTH_APPLE_SIGNIN_KEY_ID=""

# ── Encryption ────────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting PII (SSN, date of birth) in the database
# Must be a 64-character hex string — generate with: openssl rand -hex 32
ENCRYPTION_KEY=""

# ── Site ──────────────────────────────────────────────────────────────────────
# Public domain used for links in outbound emails (e.g. app.yourdomain.com)
# Leave blank to default to http://localhost:3000 in development
SITE_DOMAIN=""

# ── Fax (Faxage) ──────────────────────────────────────────────────────────────
FAXAGE_USERNAME=""
FAXAGE_COMPANY=""
FAXAGE_PASSWORD=""
# Secret used to verify incoming Faxage webhook payloads
FAXAGE_WEBHOOK_SECRET=""
# Public URL Faxage will POST status updates to (e.g. https://yourapp.com/api/fax/confirm)
FAXAGE_NOTIFY_URL=""

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Leave blank to log emails to the console instead of sending (safe for local dev)
RESEND_API_KEY=""
# Sender address shown in outbound emails (e.g. noreply@yourdomain.com)
# Resend also accepts "Display Name <email>" format
EMAIL_FROM=""

# ── File Storage (Cloudflare R2 / S3-compatible) ──────────────────────────────
R2_ACCOUNT_ID=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
