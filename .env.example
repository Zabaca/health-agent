# ── Database ──────────────────────────────────────────────────────────────────
# libsql connection URL (e.g. file:local.db for local dev, or a Turso remote URL)
DATABASE_URL=""
# Auth token required for remote Turso connections; leave blank for local file DBs
DATABASE_AUTH_TOKEN=""

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret used to sign NextAuth JWTs — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Use the same Client ID for the web "Authorized JavaScript origins" callback
# AND for the mobile Google sign-in SDK (mobile sends the resulting ID token to
# /api/auth/google/mobile, which verifies it server-side).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Apple Sign in with Apple — create a Services ID at
# https://developer.apple.com/account/resources/identifiers/list/serviceId
# AUTH_APPLE_ID is the Services ID (e.g. com.zabaca.healthagent.web).
# AUTH_APPLE_SECRET is a JWT signed with your Apple key — see Auth.js docs for
# the generation script: https://authjs.dev/getting-started/providers/apple
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# ── Encryption ────────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting PII (SSN, date of birth) in the database
# Must be a 64-character hex string — generate with: openssl rand -hex 32
ENCRYPTION_KEY=""

# ── Site ──────────────────────────────────────────────────────────────────────
# Public domain used for links in outbound emails (e.g. app.yourdomain.com)
# Leave blank to default to http://localhost:3000 in development
SITE_DOMAIN=""

# ── Fax (Faxage) ──────────────────────────────────────────────────────────────
FAXAGE_USERNAME=""
FAXAGE_COMPANY=""
FAXAGE_PASSWORD=""
# Secret used to verify incoming Faxage webhook payloads
FAXAGE_WEBHOOK_SECRET=""
# Public URL Faxage will POST status updates to (e.g. https://yourapp.com/api/fax/confirm)
FAXAGE_NOTIFY_URL=""

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Leave blank to log emails to the console instead of sending (safe for local dev)
RESEND_API_KEY=""
# Sender address shown in outbound emails (e.g. noreply@yourdomain.com)
# Resend also accepts "Display Name <email>" format
EMAIL_FROM=""

# ── File Storage (Cloudflare R2 / S3-compatible) ──────────────────────────────
R2_ACCOUNT_ID=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
